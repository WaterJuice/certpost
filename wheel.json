{
    "name": "certpost",
    "description": "Let's Encrypt certificate manager with DNS-01 challenges, web admin panel, and TLS termination proxy",
    "author": "WaterJuice",
    "license": "Unlicense",
    "homepage": "https://github.com/WaterJuice/certpost",
    "readme": "README.md",
    "classifiers": [
        "Programming Language :: Go"
    ],
    "binaries": {
        "macos_arm64": [
            {"name": "certpost-server", "path": "dist/certpost-server-darwin-arm64"},
            {"name": "certpost", "path": "dist/certpost-darwin-arm64"}
        ],
        "macos_amd64": [
            {"name": "certpost-server", "path": "dist/certpost-server-darwin-amd64"},
            {"name": "certpost", "path": "dist/certpost-darwin-amd64"}
        ],
        "linux_amd64": [
            {"name": "certpost-server", "path": "dist/certpost-server-linux-amd64"},
            {"name": "certpost", "path": "dist/certpost-linux-amd64"}
        ],
        "linux_arm64": [
            {"name": "certpost-server", "path": "dist/certpost-server-linux-arm64"},
            {"name": "certpost", "path": "dist/certpost-linux-arm64"}
        ],
        "windows_amd64": [
            {"name": "certpost-server", "path": "dist/certpost-server-windows-amd64.exe"},
            {"name": "certpost", "path": "dist/certpost-windows-amd64.exe"}
        ],
        "windows_arm64": [
            {"name": "certpost-server", "path": "dist/certpost-server-windows-arm64.exe"},
            {"name": "certpost", "path": "dist/certpost-windows-arm64.exe"}
        ]
    },
    "output-dir": "output"
}
